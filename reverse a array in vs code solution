#include <iostream>
using namespace std;
void reversearray(int arr[],int n){
    int start =0;
    int end = n-1;
    while(start<end){
        swap(arr[start],arr[end];
        start++;
        end--;
    }
    for(int i=0;i<n;i++){
        cout<<arr[i];
    }

}
int main(){
   const int size = 7;
    int brr[7];
    for(int i=0;i<size;i++){
        cin>>brr[i];
    }
    reversearray(brr,size);
    return 0;
}
