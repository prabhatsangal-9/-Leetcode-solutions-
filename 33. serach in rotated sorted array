
#include <iostream>
#include <vector>
using namespace std;
int getpivot(vector<int>& nums, int target){
    int start = 0;
    int end = nums.size() - 1;
    
    while(start < end){
        int mid = start + (end - start) / 2;
        ी
        if(nums[mid] >= nums[0]){ 
            start = mid + 1;
        }
        else{
            end = mid;
        }
    }
    return start;
}
int binaryserach(vector<int>& nums, int target, int start, int end){
    while(start <= end){
        int mid = start + (end - start) / 2;
        
        if(nums[mid] == target){
            return mid;
        }
        else if(nums[mid] > target){
            end = mid - 1;
        }
        else{
            start = mid + 1;
        }
    }
    return -1;
}

class Solution {
public:
    int search(vector<int>& nums, int target) {
        int n = nums.size(); 
        if(n == 0) return -1;
        
        int pivot = getpivot(nums, target);
        
        if(target >= nums[pivot] && target <= nums[n-1]){
            return binaryserach(nums, target, pivot, n-1);
        }
        else{
            return binaryserach(nums, target, 0, pivot-1);
        }
    }
};
